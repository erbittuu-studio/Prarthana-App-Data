      "verses": [
        { "id": 1, "first": "आरती कुंजबिहारी की", "second": "श्री गिरिधर कृष्ण मुरारी की" },
        { "id": 2, "first": "गले में बैजंती माला", "second": "बजावे मुरली मधुर बाला" },
        { "id": 3, "first": "श्रवण में कुण्डल झलकाला", "second": "नंद के आनंद नंदलाला" },
        { "id": 4, "first": "गगन सम अंग कांति काली", "second": "राधिका चमक रही आली" },
        { "id": 5, "first": "लतन में ठाढ़े बनमाली", "second": "भ्रमत रहे नंद के लाला" },
        { "id": 6, "first": "कन्हैया आरती करत", "second": "यशोदा हर्षित होय" },
        { "id": 7, "first": "कनक थार दीपक भर", "second": "आवत में लखि जोय" },
        { "id": 8, "first": "भँवर घुँघट पट खोल", "second": "राधिका रूप निहारे" },
        { "id": 9, "first": "मोहनी मूर्ति सांवरे", "second": "नयन बने रसिया की" },
        { "id": 10, "first": "आरती कुंजबिहारी की", "second": "श्री गिरिधर कृष्ण मुरारी की" }
      ]
