{
  "sections": [
    {
      "id": "aarti",
      "verses": [
        { "id": 1, "first": "આરતી કુંજબિહારી કી", "second": "શ્રી ગિરિધર કૃષ્ણ મુરારી કી" },
        { "id": 2, "first": "ગલે મેં બૈજંતી માલા", "second": "બજાવે મુરલી મધુર બાલા" },
        { "id": 3, "first": "શ્રવણ મેં કુંડલ ઝલકાલા", "second": "નંદ કે આનંદ નંદલાલા" },
        { "id": 4, "first": "ગગન સમ અંગ કાંતિ કાલી", "second": "રાધિકા ચમક રહી આલી" },
        { "id": 5, "first": "લતન મેં ઠાડે બનમાલી", "second": "ભ્રમત રહે નંદ કે લાલા" },
        { "id": 6, "first": "કન્હૈયા આરતી કરત", "second": "યશોદા હર્ષિત હોય" },
        { "id": 7, "first": "કનક થાર દીપક ભર", "second": "આવત મેં લખિ જોય" },
        { "id": 8, "first": "ભંવર ઘૂંઘટ પટ ખોલ", "second": "રાધિકા રૂપ નિહારે" },
        { "id": 9, "first": "મોહની મૂર્તિ સાંવરે", "second": "નયન બને રસિયા કી" },
        { "id": 10, "first": "આરતી કુંજબિહારી કી", "second": "શ્રી ગિરિધર કૃષ્ણ મુરારી કી" }
      ]
    }
  ]
