{
  "sections": [
    {
      "id": "opening",
      "verses": [
          {  "id": 1,  "first": "श्रीगुरु चरन सरोज रज, निज मन मुकुरु सुधारि",  "second": "बरनउँ रघुबर बिमल जसु, जो दायक फल चारि"},
          {  "id": 2,  "first": "बुद्धिहीन तनु जानिके, सुमिरौं पवन-कुमार",  "second": "बल बुद्धि विद्या देहु मोहिं, हरहु कलेस विकार"}
      ]
    },
    {
      "id": "chaupai",
      "verses": [
          {"id": 3, "first": "जय हनुमान ज्ञान गुन सागर", "second": "जय कपीस तिहुँ लोक उजागर"},
          {"id": 4, "first": "राम दूत अतुलित बल धामा","second": "अंजनि-पुत्र पवनसुत नामा"},
          {"id": 5, "first": "महाबीर विक्रम बजरंगी", "second": "कुमति निवार सुमति के संगी"},
          {"id": 6, "first": "कंचन बरन बिराज सुबेसा", "second": "कानन कुंडल कुंचित केसा" },
          { "id": 7, "first": "हाथ वज्र औ ध्वजा बिराजे", "second": "काँधे मूंज जनेऊ साजे"},
          {  "id": 8,  "first": "शंकर सुवन केसरी नंदन",  "second": "तेज प्रताप महा जग बंदन"},
          {  "id": 9,  "first": "विद्यावान गुनी अति चातुर",  "second": "राम काज करिबे को आतुर"},
          {  "id": 10,  "first": "प्रभु चरित्र सुनिबे को रसिया",  "second": "राम लखन सीता मन बसिया"},
          {  "id": 11,  "first": "सूक्ष्म रूप धरि सियहिं दिखावा",  "second": "बिकट रूप धरि लंक जरावा"},
          {  "id": 12,  "first": "भीम रूप धरि असुर संहारे",  "second": "रामचंद्र के काज संवारे"},
          {  "id": 13,  "first": "लाय सजीवन लखन जियाए",  "second": "श्री रघुबीर हरषि उर लाए"},
          {  "id": 14,  "first": "रघुपति कीन्ही बहुत बड़ाई",  "second": "तुम मम प्रिय भरतहि सम भाई"},
          {  "id": 15,  "first": "सहस बदन तुम्हरो जस गावैं",  "second": "अस कहि श्रीपति कंठ लगावैं"},
          {  "id": 16,  "first": "सनकादिक ब्रह्मादि मुनीसा",  "second": "नारद सारद सहित अहीसा"},
          {  "id": 17,  "first": "जम कुबेर दिगपाल जहाँ ते",  "second": "कवि कोविद कहि सके कहाँ ते"},
          {  "id": 18,  "first": "तुम उपकार सुग्रीवहिं कीन्हा",  "second": "राम मिलाय राज पद दीन्हा"},
          {  "id": 19,  "first": "तुम्हरो मंत्र विभीषन माना",  "second": "लंकेश्वर भए सब जग जाना"},
          {  "id": 20,  "first": "जुग सहस्र योजन पर भानु",  "second": "लील्यो ताहि मधुर फल जानू"},
          {  "id": 21,  "first": "प्रभु मुद्रिका मेलि मुख माहीं",  "second": "जलधि लांघि गए अचरज नाहीं"},
          {  "id": 22,  "first": "दुर्गम काज जगत के जेते",  "second": "सुगम अनुग्रह तुम्हरे तेते"},
          {  "id": 23,  "first": "राम दुआरे तुम रखवारे",  "second": "होत न आज्ञा बिनु पैसारे"},
          {  "id": 24,  "first": "सब सुख लहै तुम्हारी सरना",  "second": "तुम रक्षक काहू को डरना"},
          {  "id": 25,  "first": "आपन तेज सम्हारो आपै",  "second": "तीनों लोक हांक ते कांपै"},
          {  "id": 26,  "first": "भूत पिशाच निकट नहिं आवै",  "second": "महावीर जब नाम सुनावै"},
          {  "id": 27,  "first": "नासै रोग हरै सब पीरा",  "second": "जपत निरंतर हनुमत बीरा"},
          {  "id": 28,  "first": "संकट तें हनुमान छुड़ावै",  "second": "मन क्रम वचन ध्यान जो लावै"},
          {  "id": 29,  "first": "सब पर राम तपस्वी राजा",  "second": "तिन के काज सकल तुम साजा"},
          {  "id": 30,  "first": "और मनोरथ जो कोई लावै",  "second": "सोई अमित जीवन फल पावै"},
          {  "id": 31,  "first": "चारों जुग परताप तुम्हारा",  "second": "है परसिद्ध जगत उजियारा"},
          {  "id": 32,  "first": "साधु संत के तुम रखवारे",  "second": "असुर निकंदन राम दुलारे"},
          {  "id": 33,  "first": "अष्ट सिद्धि नौ निधि के दाता",  "second": "अस बर दीन जानकी माता"},
          {  "id": 34,  "first": "राम रसायन तुम्हरे पासा",  "second": "सदा रहो रघुपति के दासा"},
          {  "id": 35,  "first": "तुम्हरे भजन राम को पावै",  "second": "जनम जनम के दुख बिसरावै"},
          {  "id": 36,  "first": "अंत काल रघुबर पुर जाई",  "second": "जहाँ जन्म हरिभक्त कहाई"},
          {  "id": 37,  "first": "और देवता चित्त न धरई",  "second": "हनुमत सेई सर्व सुख करई"},
          {  "id": 38,  "first": "संकट कटै मिटै सब पीरा",  "second": "जो सुमिरै हनुमत बलबीरा"},
          {  "id": 39,  "first": "जय जय जय हनुमान गोसाईं",  "second": "कृपा करहु गुरुदेव की नाईं"},
          {  "id": 40,  "first": "जो सत बार पाठ कर कोई",  "second": "छूटहि बंदि महा सुख होई"},
          {  "id": 41,  "first": "जो यह पढ़ै हनुमान चालीसा",  "second": "होय सिद्धि साखी गौरीसा"},
          {  "id": 42,  "first": "तुलसीदास सदा हरि चेरा",  "second": "कीजै नाथ हृदय महँ डेरा"}
      ]
    },
    {
      "id": "closing",
      "verses": [
          {  "id": 43,  "first": "पवन तनय संकट हरन, मंगल मूर्ति रूप",  "second": "राम लखन सीता सहित, हृदय बसहु सुर भूप"}
      ]
    }
  ]
}
