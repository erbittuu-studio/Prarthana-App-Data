      "id": "main",
      "verses": [
        { "id": 1, "first": "સુખકર્તા દુઃખહર્તા વાર્તા વિઘ્નાચી", "second": "નુરવી પુરવી પ્રેમ કૃપા જયાચી" },
        { "id": 2, "first": "સર્વાંગી સુંદર ઉટી શેંદુરાચી", "second": "કંઠી ઝળકે માળ મુક્તાફળાંચી ॥" },
        { "id": 3, "first": "જય દેવ જય દેવ જય મંગલમૂર્તી", "second": "દર્શનમાત્રે મન કામના પુરતી ॥" },
        { "id": 4, "first": "રત્નખચિત ફરા તુજ ગૌરીકુમરા", "second": "ચંદનાચી ઉટી કુમકુમ કેશરા" },
        { "id": 5, "first": "હિરે જડિત મુકુટ શોભતો બરા", "second": "રુણઝુણતી નૂપુરે ચરણી ઘાઘરિયા ॥" },
        { "id": 6, "first": "જય દેવ જય દેવ જય મંગલમૂર્તી", "second": "દર્શનમાત્રે મન કામના પુરતી ॥" },
        { "id": 7, "first": "લંબોદર પીતાંબર ફણિવરબંધના", "second": "સરળ સોંડ વક્રતુંડ ત્રિનયના" },
        { "id": 8, "first": "દાસ રામાચા વાટ પાહે સદના", "second": "સંકટી પાવાવે નિર્વાણી રક્ષાવે સુરવરવંદના ॥" },
        { "id": 9, "first": "જય દેવ જય દેવ જય મંગલમૂર્તી", "second": "દર્શનમાત્રે મન કામના પુરતી ॥" }
      ]
