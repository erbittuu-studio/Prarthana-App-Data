{
  "sections": [
    {
      "id": "aarti",
      "verses": [
        { "id": 1, "first": "આરતી કીજે હનુમાન લલા કી", "second": "દુષ્ટદલન રઘુનાથ કલા કી" },
        { "id": 2, "first": "જાકે બલ સે ગિરિવર કાંપે", "second": "રોગ દોષ જાકે નિકટ ન ઝાંકે" },
        { "id": 3, "first": "અંજનિ પુત્ર મહા બલદાયી", "second": "સંતન કે પ્રભુ સદા સહાયી" },
        { "id": 4, "first": "દે બીરા રઘુનાથ પઠાયે", "second": "લંકા જારિ સિયા સુધિ લાયે" },
        { "id": 5, "first": "લંકા સો કોટ સમુદ્ર સિહાયી", "second": "જાત પવનસુત બાર ન લાયી" },
        { "id": 6, "first": "લક્ષ્મણ મૂર્છિત પડે સકારે", "second": "આનહુ ઔષધિ પ્રાણ ઉબારે" },
        { "id": 7, "first": "પૈઠ પતાલ તોરિ જમ કરે", "second": "અહિરાવણ કી ભુજા ઉખારે" },
        { "id": 8, "first": "બાયેં ભુજા ગિરિ સંજીવી", "second": "દાયેં ભુજા અહિરાવણ લેવી" },
        { "id": 9, "first": "સુર નર મુનિ આરતી ઉતારે", "second": "જય જય જય હનુમાન ઉચારે" },
        { "id": 10, "first": "કંચન થાર કપૂર કી બાતી", "second": "આરતી કરે જન હરષે છાતી" },
        { "id": 11, "first": "જો હનુમાન જી કી આરતી ગાવે", "second": "સો બૈકુંઠ પરમ પદ પાવે" }
      ]
    }
  ]
}
