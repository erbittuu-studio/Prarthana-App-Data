{
  "sections": [
    {
      "id": "aarti",
      "verses": [
        { "id": 1, "first": "आरती कीजै हनुमान लला की", "second": "दुष्टदलन रघुनाथ कला की" },
        { "id": 2, "first": "जाके बल से गिरिवर काँपे", "second": "रोग दोष जाके निकट न झाँके" },
        { "id": 3, "first": "अंजनि पुत्र महा बलदायी", "second": "संतन के प्रभु सदा सहायी" },
        { "id": 4, "first": "दे बीरा रघुनाथ पठाये", "second": "लंका जारि सिया सुधि लाये" },
        { "id": 5, "first": "लंका सो कोट समुद्र सिहायी", "second": "जात पवनसुत बार न लायी" },
        { "id": 6, "first": "लक्ष्मण मूर्छित पड़े सकारे", "second": "आनहु ओषधि प्राण उबारे" },
        { "id": 7, "first": "पैठ पताल तोरि जम करे", "second": "अहिरावण की भुजा उखारे" },
        { "id": 8, "first": "बायें भुजा गिरि संजीवी", "second": "दायें भुजा अहिरावण लेवी" },
        { "id": 9, "first": "सुर नर मुनि आरती उतारे", "second": "जय जय जय हनुमान उचारे" },
        { "id": 10, "first": "कंचन थार कपूर की बाती", "second": "आरती करे जन हरषे छाती" },
        { "id": 11, "first": "जो हनुमान जी की आरती गावे", "second": "सो बैकुण्ठ परम पद पावे" }
      ]
    }
  ]
}
