{
  "sections": [
    {
      "id": "doha",
      "verses": [
        { "id": 1, "first": "नमो नमो दुर्गे सुख करनी", "second": "नमो नमो अम्बे दुख हरनी" },
        { "id": 2, "first": "निरंकार है ज्योति तुम्हारी", "second": "तिहुं लोक फैली उजियारी" }
      ]
    },
    {
      "id": "chaupai",
      "verses": [
        { "id": 3, "first": "शशि ललाट मुख महाविशाला", "second": "नेत्र लाल भृकुटी विकराला" },
        { "id": 4, "first": "रूप मातु को अधिक सुहावे", "second": "दरस करत जन अति सुख पावे" },
        { "id": 5, "first": "तुम संसार शक्ति लय कीना", "second": "पालन हेतु अन्न धन दीना" },
        { "id": 6, "first": "अन्नपूर्णा हुई जग पाला", "second": "तुम ही आदि सुंदरी बाला" },
        { "id": 7, "first": "प्रलयकाल सब नाशन हारी", "second": "तुम गौरी शिव शंकर प्यारी" },
        { "id": 8, "first": "शिव योगी तुम्हरे गुण गावें", "second": "ब्रह्मा विष्णु तुम्हें नित ध्यावें" },
        { "id": 9, "first": "रूप सरस्वती को तुम धारा", "second": "दे सुबुद्धि ऋषि मुनिन उबारा" },
        { "id": 10, "first": "धरयो रूप नरसिंह को अम्बा", "second": "प्रगट भई फार कर के खम्बा" },
        { "id": 11, "first": "रक्षा करी प्रहलाद बचायो", "second": "हिरण्याक्ष को स्वर्ग पठायो" },
        { "id": 12, "first": "लक्ष्मी रूप धरो जग माहीं", "second": "श्री नारायण अंग समाहीं" },
        { "id": 13, "first": "क्षीर सिंधु में करत विलासा", "second": "दया सिंधु दीजै मन आसा" },
        { "id": 14, "first": "हिंगलाज में तुम्हीं भवानी", "second": "महिमा अमित न जात बखानी" },
        { "id": 15, "first": "मातंगी धूमावती माता", "second": "भुवनेश्वरी बगला सुखदाता" },
        { "id": 16, "first": "श्री भैरव तारा जग तारिणी", "second": "छिन्न भाल भव दुख निवारिणी" },
        { "id": 17, "first": "केहरी वाहन सोह भवानी", "second": "लांगुर वीर चलत अगवानी" },
        { "id": 18, "first": "कर में खप्पर खड्ग विराजे", "second": "जाको देख काल डर भाजे" },
        { "id": 19, "first": "सोहे अस्त्र और त्रिशूला", "second": "जसे उठ काल कपाल फूला" },
        { "id": 20, "first": "नागरकोट में तुम्हीं विराजत", "second": "तिहुं लोक में डंका बाजत" },
        { "id": 21, "first": "शुम्भ निशुम्भ दानुज तुम मारे", "second": "रक्त बीज शंखन संघारे" },
        { "id": 22, "first": "महिषासुर नृप अति अभिमानी", "second": "जेहि अघ भार मही अकुलानी" },
        { "id": 23, "first": "रूप कराल कालिका धारा", "second": "सेन सहित तुम तिहि संघारा" },
        { "id": 24, "first": "परी गढ़ पर संतन राखी", "second": "रूप चांडी का तुम धरि साखी" },
        { "id": 25, "first": "महाकाल शंकर कहि गये", "second": "आज भी नित तुम्हरे गुण गये" },
        { "id": 26, "first": "झण्डू झण्डा और नगारा", "second": "सुनति दुंदुभि ध्वनि सघारा" },
        { "id": 27, "first": "तेरी शक्ति संसार सारा", "second": "कही न सके गुण पार तुम्हारा" },
        { "id": 28, "first": "चौसठ योगिनी मंगल गावें", "second": "नृत्य करत तुम सुरन सुहावें" },
        { "id": 29, "first": "तुमको निरखें गौरी लखी", "second": "चंद्र चक्र दोनों में दाखी" },
        { "id": 30, "first": "कर जोड़े सब भगत तुम्हारे", "second": "संकट में जो तुम्हीं पुकारे" },
        { "id": 31, "first": "संकट तुरत दूर करहु माँ", "second": "शरण गया को काहु न दहु माँ" },
        { "id": 32, "first": "स्वर्ग से लेकर आई", "second": "स्वयं सिंधु भागीरथी देवी" },
        { "id": 33, "first": "पाप करत है पातक भारी", "second": "स्वर्ग में है पथ करनी" },
        { "id": 34, "first": "चाहत सुख ऐश्वर्य अनंता", "second": "माँ तुम्हीं आदि देवी शक्ति महंता" },
        { "id": 35, "first": "दुर्गा स्त्रोत पाठ कर कोई", "second": "न रहे दुखी धरती सोई" },
        { "id": 36, "first": "जो ये पाठ करे धरी ध्याना", "second": "उनके बिनु ग्रहण कल्याण" },
        { "id": 37, "first": "करता रे पावे लक्ष्मी", "second": "सुख संपति बहुत की दिखी" },
        { "id": 38, "first": "पुत्रहीन जो पाठ करनी", "second": "पुत्रवती वो मात कहलायी" },
        { "id": 39, "first": "मातु तुम्हरी है यही शक्ति", "second": "और आनंद दे नहीं मुक्ति" },
        { "id": 40, "first": "जब मेरी दुख सहे न जाये", "second": "तब मेरी सुधि लेना माता आये" },
        { "id": 41, "first": "दुर्गा पाठ निशदिन जो गावे", "second": "संकट मुख सुख संपति पावे" },
        { "id": 42, "first": "देवीदास शरण निज जानी", "second": "करो कृपा जगदम्ब भवानी" }
      ]
    },
    {
      "id": "doha_closing",
      "verses": [
        { "id": 43, "first": "मात पिता तुम मेरे शरण गहूं", "second": "किसकी और न आँच कहूं" },
        { "id": 44, "first": "तुम बिन और न कोई हमारा", "second": "भवसागर से उतरा ले प्यारा" }
      ]
    }
  ]
