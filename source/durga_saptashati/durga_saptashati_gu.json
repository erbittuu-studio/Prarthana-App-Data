{
  "sections": [
    {
      "id": "kavach",
      "verses": [
        { "id": 1, "first": "ૐ અસ્ય શ્રી ચંડી કવચસ્ય", "second": "બ્રહ્મ ઋષિ અનુષ્ટુપ છંદઃ" },
        { "id": 2, "first": "ચામુંડા દેવતા", "second": "અંગન્યાસ ઉક્તં માત્રં" },
        { "id": 3, "first": "નવાર્ણ મંત્રો બીજં", "second": "શ્રી શક્તિ સપ્તશતી પાઠે વિનિયોગઃ" }
      ]
    },
    {
      "id": "dhyan",
      "verses": [
        { "id": 4, "first": "ૐ જય ત્વં દેવી ચામુંડે", "second": "જય ભૂતાપહારિણી" },
        { "id": 5, "first": "જય સર્વગતે દેવી", "second": "કાલ રાત્રિ નમોસ્તુ તે" }
      ]
    },
    {
      "id": "path",
      "verses": [
        { "id": 6, "first": "શૂલં શૂલવતી રક્ષતુ", "second": "મુસલં મુસલી તથા" },
        { "id": 7, "first": "ખડ્ગં ખડ્ગિની રક્ષતુ", "second": "ઘંટં ઘંટિની ચક્રિંકમ" },
        { "id": 8, "first": "પ્રાચ્યાં રક્ષતુ માં ઐંદ્રી", "second": "આગ્નેયાં અગ્નિદેવતા" },
        { "id": 9, "first": "દક્ષિણે અવતુ વારાહી", "second": "નૈર્યત્યાં ખડ્ગધારિણી" },
        { "id": 10, "first": "પ્રતીચ્યાં વારુણી રક્ષેદ", "second": "વાયવ્યાં મૃગ વાહિની" },
        { "id": 11, "first": "ઉદીચ્યાં પાતુ કૌમારી", "second": "ઐશાન્યાં શૂલ ધારિણી" },
        { "id": 12, "first": "ઊર્ધ્વં બ્રહ્માણી મે રક્ષેદ", "second": "અધસ્તાત વૈષ્ણવી તથા" },
        { "id": 13, "first": "એવં દશ દિશો રક્ષેચ", "second": "ચામુંડા શવ વાહના" }
      ]
    },
    {
      "id": "phalashruti",
      "verses": [
        { "id": 14, "first": "ય ઇદં કવચં દેવી", "second": "પઠેત સિદ્ધિ યુક્તો ભવેત" },
        { "id": 15, "first": "ન તસ્ય જાયતે કિંચિત", "second": "અશુભં રણસંકટે" },
        { "id": 16, "first": "નાપદં તસ્ય પશ્યામિ", "second": "શોક દુખ ભયં ન હિ" }
      ]
    }
  ]
