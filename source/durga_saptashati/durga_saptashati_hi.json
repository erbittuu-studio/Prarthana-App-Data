{
  "sections": [
    {
      "id": "kavach",
      "verses": [
        { "id": 1, "first": "ॐ अस्य श्री चण्डी कवचस्य", "second": "ब्रह्म ऋषि अनुष्टुप छंदः" },
        { "id": 2, "first": "चामुंडा देवता", "second": "अंगन्यास उक्तं मात्रं" },
        { "id": 3, "first": "नवार्ण मंत्रो बीजं", "second": "श्री शक्ति सप्तशती पाठे विनियोगः" }
      ]
    },
    {
      "id": "dhyan",
      "verses": [
        { "id": 4, "first": "ॐ जय त्वं देवी चामुंडे", "second": "जय भूतापहारिणी" },
        { "id": 5, "first": "जय सर्वगते देवी", "second": "काल रात्रि नमोस्तु ते" }
      ]
    },
    {
      "id": "path",
      "verses": [
        { "id": 6, "first": "शूलं शूलवती रक्षतु", "second": "मुसलं मुसली तथा" },
        { "id": 7, "first": "खड्गं खड्गिनी रक्षतु", "second": "घंटं घंटिनी चक्रिंकम" },
        { "id": 8, "first": "प्राच्यां रक्षतु मां ऐंद्री", "second": "आग्नेयां अग्निदेवता" },
        { "id": 9, "first": "दक्षिणे अवतु वाराही", "second": "नैर्यत्यां खड्गधारिणी" },
        { "id": 10, "first": "प्रतीच्यां वारुणी रक्षेद", "second": "वायव्यां मृग वाहिनी" },
        { "id": 11, "first": "उदीच्यां पातु कौमारी", "second": "ऐशान्यां शूल धारिणी" },
        { "id": 12, "first": "ऊर्ध्वं ब्रह्माणी मे रक्षेद", "second": "अधस्तात वैष्णवी तथा" },
        { "id": 13, "first": "एवं दश दिशो रक्षेच", "second": "चामुंडा शव वाहना" }
      ]
    },
    {
      "id": "phalashruti",
      "verses": [
        { "id": 14, "first": "य इदं कवचं देवी", "second": "पठेत सिद्धि युक्तो भवेत" },
        { "id": 15, "first": "न तस्य जायते किंचित", "second": "अशुभं रणसंकटे" },
        { "id": 16, "first": "नापदं तस्य पश्यामि", "second": "शोक दुख भयं न हि" }
      ]
    }
  ]
}
