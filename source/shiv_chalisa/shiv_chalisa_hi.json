{
  "sections": [
    {
      "id": "doha",
      "verses": [
        { "id": 1, "first": "जय गणेश गिरिजा सुवन, मंगल मूल सुजान", "second": "कहत अयोध्यादास तुम, देहु अभय वरदान" },
        { "id": 2, "first": "जय गिरिजा पति दीन दयाला", "second": "सदा करत संतन प्रतिपाला" }
      ]
    },
    {
      "id": "main",
      "verses": [
        { "id": 1, "first": "भाल चंद्रमा सोहत नीके", "second": "कानन कुंडल नागफनी के" },
        { "id": 2, "first": "अंग गौर शिर गंग बहाये", "second": "मुंडमाल तन क्षार लगाये" },
        { "id": 3, "first": "वस्त्र खाल बाघम्बर सोहे", "second": "छवि को देख नाग मुनि मोहे" },
        { "id": 4, "first": "मैना मातु की हवे दुलारी", "second": "वाम अंग सोहत छवि न्यारी" },
        { "id": 5, "first": "कर त्रिशूल सोहत छवि भारी", "second": "करत सदा शत्रुन क्षयकारी" },
        { "id": 6, "first": "नंदि गणेश सोहै तहं कैसे", "second": "सागर मध्य कमल है जैसे" },
        { "id": 7, "first": "कार्तिक श्याम और गणराऊ", "second": "या छवि को कहि जात न काऊ" },
        { "id": 8, "first": "देवन जबहीं जाय पुकारा", "second": "तब ही दुख प्रभु आप निवारा" },
        { "id": 9, "first": "किया उपद्रव तारक भारी", "second": "देवन सब मिलि तुमहीं जुहारी" },
        { "id": 10, "first": "तुरत षडानन आप पठायउ", "second": "लवनिमेष महं मारि गिरायउ" },
        { "id": 11, "first": "आप जलंधर असुर संहारा", "second": "सुयश तुम्हार विदित संसारा" },
        { "id": 12, "first": "त्रिपुरासुर सन युद्ध मचाई", "second": "सबहिं कृपा कर लीन बचाई" },
        { "id": 13, "first": "किया तपहिं भागीरथ भारी", "second": "पुरव प्रतिज्ञा तासु पुरारी" },
        { "id": 14, "first": "दानिन महं तुम सम कोउ नाहीं", "second": "सेवक स्तुति करत सदाहीं" },
        { "id": 15, "first": "वेद नाम महिमा तव गाई", "second": "अकथ अनादि भेद नहिं पाई" },
        { "id": 16, "first": "प्रगट उदधि मंथन में ज्वाला", "second": "जरत सुरासुर भए विहाला" },
        { "id": 17, "first": "कीन्ह दया तहं करी सहाई", "second": "नीलकंठ तब नाम कहाई" },
        { "id": 18, "first": "पूजन रामचंद्र जब कीन्हा", "second": "जीत के लंक विभीषण दीन्हा" },
        { "id": 19, "first": "सहस कमल में हो रहे धारी", "second": "कीन्ह परीक्षा तबहिं पुरारी" },
        { "id": 20, "first": "एक कमल प्रभु राखेउ जोई", "second": "कमल नयन पूजन चहं सोई" },
        { "id": 21, "first": "कठिन भक्ति देखी प्रभु शंकर", "second": "भए प्रसन्न दिए इच्छित वर" },
        { "id": 22, "first": "जय जय जय अनंत अविनाशी", "second": "करत कृपा सब के घट वासी" },
        { "id": 23, "first": "दुष्ट सकल नित मोहि सतावे", "second": "भ्रमत रहे मोहि चैन न आवे" },
        { "id": 24, "first": "त्राहि त्राहि मैं नाथ पुकारो", "second": "यहि अवसर मोहि आन उबारो" },
        { "id": 25, "first": "लै त्रिशूल शत्रुन को मारो", "second": "संकट ते मोहि आन उबारो" },
        { "id": 26, "first": "मातु पिता भ्राता सब कोई", "second": "संकट में पूछत नहिं कोई" },
        { "id": 27, "first": "स्वामी एक है आस तुम्हारी", "second": "आय हरहु अब संकट भारी" },
        { "id": 28, "first": "धन निर्धन को देत सदाहीं", "second": "जो कोई जांचे सो फल पाहीं" },
        { "id": 29, "first": "अस्तुति केहि विधि करौं तुम्हारी", "second": "क्षमहु नाथ अब चूक हमारी" },
        { "id": 30, "first": "शंकर हो संकट के नाशन", "second": "मंगलकारी विघ्न विनाशन" },
        { "id": 31, "first": "योगी यति मुनि ध्यान लगावें", "second": "शारद नारद शीश नवावें" },
        { "id": 32, "first": "नमो नमो जय नमो शिवाय", "second": "सुर ब्रह्मादिक पार न पाय" },
        { "id": 33, "first": "जो यह पाठ करे मन लाई", "second": "ता पर होत है शम्भु सहाई" },
        { "id": 34, "first": "ऋनिया जो कोई हो अधिकारी", "second": "पाठ करे सो पावन हारी" },
        { "id": 35, "first": "पुत्रहीन जो इच्छा करई", "second": "निश्चय शिव प्रसाद तेहि मिलई" },
        { "id": 36, "first": "पंडित त्रयोदशी को लावे", "second": "ध्यान पूर्वक होम करावे" },
        { "id": 37, "first": "त्रयोदशी व्रत करे हमेशा", "second": "तन नहीं ताके रहे कलेशा" },
        { "id": 38, "first": "धूप दीप नैवेद्य चढ़ावे", "second": "शंकर सम्मुख पाठ सुनावे" },
        { "id": 39, "first": "जन्म जन्म की पाप नशावे", "second": "अंतवास शिवपुर में पावे" },
        { "id": 40, "first": "कहें अयोध्यादास आस तुम्हारी", "second": "जानि सकल दुख हरहु हमारी" }
      ]
    },
    {
      "id": "doha_end",
      "verses": [
        { "id": 1, "first": "नित नेम कर प्रातः ही, पाठ करो चालीस", "second": "तुम मेरी मनोकामना, पूर्ण करो जगदीश" },
        { "id": 2, "first": "॥ इति श्री शिव चालीसा समाप्त ॥", "second": "" }
      ]
    }
  ]
}
