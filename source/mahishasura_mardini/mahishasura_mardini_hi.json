{
  "sections": [
    {
      "id": "stotram",
      "verses": [
        { "id": 1, "first": "अयि गिरि नंदिनि नंदितमेदिनी", "second": "विश्व विनोदिनी नंदनुते" },
        { "id": 2, "first": "गिरिवर विंध्य शिरोधि निवासिनी", "second": "विष्णु विलासिनी जिष्णुनुते" },
        { "id": 3, "first": "भगवति हे शितिकंठ कुटुम्बिनी", "second": "भूरि कुटुम्बिनी भूरि कृते" },
        { "id": 4, "first": "जय जय हे महिषासुर मर्दिनी", "second": "रम्य कपर्दिनी शैलसुते" },
        { "id": 5, "first": "सुरवरवर्षिणी दुर्धर धर्षिणी", "second": "दुर्मुख मर्षिणी हर्षरते" },
        { "id": 6, "first": "त्रिभुवन पोषिणी शंकर तोषिणी", "second": "किल्बिष मोषिणी घोषरते" },
        { "id": 7, "first": "दनुज निरोषिणी दितिसुत रोषिणी", "second": "दुर्मद शोषिणी सिंधु सुते" },
        { "id": 8, "first": "जय जय हे महिषासुर मर्दिनी", "second": "रम्य कपर्दिनी शैलसुते" },
        { "id": 9, "first": "अयि जगदम्बा मदम्बा कदम्बवन", "second": "प्रियवास विवासिवधू जुते" },
        { "id": 10, "first": "शिखरि शिरोमणि तुंगहिमालय", "second": "शृंग निजालय मध्य गुते" },
        { "id": 11, "first": "मधुमधुरे मधुकैटभभंजिनी", "second": "कैटभ भंजिनी रासरते" },
        { "id": 12, "first": "जय जय हे महिषासुर मर्दिनी", "second": "रम्य कपर्दिनी शैलसुते" },
        { "id": 13, "first": "अयि शतखण्ड विखण्डितरुण्ड वितुण्डितशुण्ड", "second": "गजाधिपते रिपुगजगण्ड विदारण" },
        { "id": 14, "first": "चण्ड पराक्रम शुण्ड मृगाधिपते", "second": "निजभुज दण्ड निपातित खण्ड" },
        { "id": 15, "first": "विपतित मुण्ड भटाधिपते", "second": "जय जय हे महिषासुर मर्दिनी रम्य कपर्दिनी शैलसुते" }
      ]
    }
  ]
}
