{
  "sections": [
    {
      "id": "stuti",
      "verses": [
        { "id": 1, "first": "प्रथमं शैलपुत्री च", "second": "द्वितीयं ब्रह्मचारिणी" },
        { "id": 2, "first": "तृतीयं चंद्रघंटेति", "second": "कूष्माण्डेति चतुर्थकम" },
        { "id": 3, "first": "पंचमं स्कंदमाता च", "second": "षष्ठम कात्यायनी तथा" },
        { "id": 4, "first": "सप्तमं कालरात्रि च", "second": "महागौरी च अष्टमम" },
        { "id": 5, "first": "नवमं सिद्धिदात्री च", "second": "नवदुर्गा प्रकीर्तिताः" },
        { "id": 6, "first": "उक्तान्येतानि नामानि", "second": "ब्रह्मणैव महात्मना" },
        { "id": 7, "first": "शैलपुत्री शुभं दद्यात", "second": "ब्रह्मचारिणी सतम" },
        { "id": 8, "first": "चंद्रघंटा शुभं दद्यात", "second": "कूष्माण्डा आरोग्यम एव च" },
        { "id": 9, "first": "स्कंदमाता सुखं दद्यात", "second": "कात्यायनी यशो बलम" },
        { "id": 10, "first": "कालरात्रि शुभं दद्यात", "second": "महागौरी तु निष्कलम" },
        { "id": 11, "first": "सिद्धिदात्री च सिद्धिम", "second": "दद्यात पुण्यं तथा" },
        { "id": 12, "first": "नवदुर्गा नमस्यामि", "second": "नवदुर्गा महोत्सवम" }
      ]
    }
  ]
}
