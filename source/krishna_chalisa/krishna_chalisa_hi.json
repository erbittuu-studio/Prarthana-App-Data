{
  "sections": [
    {
      "id": "doha",
      "verses": [
        { "id": 1, "first": "श्री कृष्ण चंद्र के चरणन में", "second": "मन वचन करम ध्यान" },
        { "id": 2, "first": "सब विधि में सेवा करूं", "second": "करहु कृपा भगवान" }
      ]
    },
    {
      "id": "chaupai",
      "verses": [
        { "id": 3, "first": "जय जय श्री कृष्ण चंद्र भगवान", "second": "जय देवकी नंदन जय भगवान" },
        { "id": 4, "first": "जय यशोदा के प्राण आधार", "second": "जय नंद के नयन तार" },
        { "id": 5, "first": "नवनीत चोर माखन खावैयां", "second": "ग्वाल बाल संग खेल मचावैयां" },
        { "id": 6, "first": "पूतना को मोक्ष दियो दान", "second": "जब तुम थे अति बाल भगवान" },
        { "id": 7, "first": "शकट असुर मर्द गये", "second": "तृणावर्त को मूड गये" },
        { "id": 8, "first": "बकासुर अघासुर मारदे", "second": "ब्रजवासी के मन हर्ष भरदे" },
        { "id": 9, "first": "कालिया नाग को नाथ लिया", "second": "बंसी बजाये ब्रज को रीत दिया" },
        { "id": 10, "first": "गोवर्धन पर्वत को धारी", "second": "लगी इंद्र की मत सुधारी" },
        { "id": 11, "first": "कंस को वध किया भगवान", "second": "उग्रसेन को दिया राज दान" },
        { "id": 12, "first": "देवकी वसुदेव को बंधन तोरे", "second": "कारागार से बाहर निकाले" },
        { "id": 13, "first": "द्वारका नगरी बसाये", "second": "रुक्मिणी संग विवाह रचाये" },
        { "id": 14, "first": "सुदामा को दिया मान बढ़ाई", "second": "दरिद्र मिटा ऐश्वर्य आई" },
        { "id": 15, "first": "अर्जुन के सारथी बने", "second": "महाभारत में धर्म सम्भाले" },
        { "id": 16, "first": "गीता ज्ञान जगत को दिया", "second": "जग का मोह भ्रम हर लिया" },
        { "id": 17, "first": "द्रौपदी की लाज बचायी", "second": "चीरहरण में शरण आयी" },
        { "id": 18, "first": "भक्त प्रहलाद को बचायो", "second": "नरसिंह रूप में आयो" },
        { "id": 19, "first": "विष्णु के अवतार तुम्हीं हो", "second": "जगत के पालनहार तुम्हीं हो" },
        { "id": 20, "first": "राधा के मन बसने वाले", "second": "मुरली की धुन सुनाने वाले" },
        { "id": 21, "first": "गोपी जन के प्राण प्यारे", "second": "रास लीला रचने वाले" },
        { "id": 22, "first": "श्री कृष्ण चालीसा जो गावे", "second": "सुख संपत्ति घर लावे" }
      ]
    },
    {
      "id": "doha_closing",
      "verses": [
        { "id": 23, "first": "कृष्ण भक्ति में जो लीन रहे", "second": "संकट सब दूर जाहे" },
        { "id": 24, "first": "जो यह पाठ करे मन लाई", "second": "कृष्ण कृपा उसपे सदा छायी" }
      ]
    }
  ]
}
