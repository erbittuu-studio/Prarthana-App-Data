      "verses": [
        { "id": 1, "first": "ૐ નમશ્ચંડિકાયૈ", "second": "માર્કંડેય ઉવાચ" },
        { "id": 2, "first": "ૐ યદ્ગુહ્યં પરમં લોકે", "second": "સર્વરક્ષાકરં નૃણામ" },
        { "id": 3, "first": "યન્ન કસ્યચિદાખ્યાતં", "second": "તન્મે બ્રૂહિ પિતામહ" },
        { "id": 4, "first": "બ્રહ્મોવાચ", "second": "અસ્તિ ગુહ્યતમં વિપ્ર" },
        { "id": 5, "first": "સર્વભૂતોપકારકમ", "second": "દેવ્યાસ્તુ કવચં પુણ્યં" },
        { "id": 6, "first": "તચ્છૃણુ શિવાર્ધકમ", "second": "પ્રથમં શૈલપુત્રી ચ" },
        { "id": 7, "first": "દ્વિતીયં બ્રહ્મચારિણી", "second": "તૃતીયં ચંદ્રઘંટેતિ" },
        { "id": 8, "first": "કૂષ્માંડેતિ ચતુર્થકમ", "second": "પંચમં સ્કંદમાતેતિ" },
        { "id": 9, "first": "ષષ્ઠં કાત્યાયની તથા", "second": "સપ્તમં કાલરાત્રિશ્ચ" },
        { "id": 10, "first": "મહાગૌરીચ અષ્ટમમ", "second": "નવમં સિદ્ધિદાત્રી ચ" },
        { "id": 11, "first": "નવદુર્ગાઃ પ્રકીર્તિતાઃ", "second": "ઉક્તાન્યેતાનિ નામાનિ" },
        { "id": 12, "first": "બ્રહ્મણૈવ મહાત્મના", "second": "અગ્નિના દહ્યમાનસ્તુ" },
        { "id": 13, "first": "શત્રુમધ્યે ગતો રણે", "second": "વિષમે દુર્ગમે ચૈવ" },
        { "id": 14, "first": "ભયાર્તઃ શરણં ગતઃ", "second": "ન તેષાં જાયતે કિંચિત" },
        { "id": 15, "first": "અશુભં રણસંકટે", "second": "નાપદં તસ્ય પશ્યામિ" },
        { "id": 16, "first": "શોક દુખં ભયં નહિ", "second": "યૈસ્તુ ભક્ત્યા સ્મૃતા નિત્યં" }
      ]
