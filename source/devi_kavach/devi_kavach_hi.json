{
  "sections": [
    {
      "id": "kavach",
      "verses": [
        { "id": 1, "first": "ॐ नमश्चण्डिकायै", "second": "मार्कण्डेय उवाच" },
        { "id": 2, "first": "ॐ यद्गुह्यं परमं लोके", "second": "सर्वरक्षाकरं नृणाम" },
        { "id": 3, "first": "यन्न कस्यचिदाख्यातं", "second": "तन्मे ब्रूहि पितामह" },
        { "id": 4, "first": "ब्रह्मोवाच", "second": "अस्ति गुह्यतमं विप्र" },
        { "id": 5, "first": "सर्वभूतोपकारकम", "second": "देव्यास्तु कवचं पुण्यं" },
        { "id": 6, "first": "तच्छृणु शिवार्धकम", "second": "प्रथमं शैलपुत्री च" },
        { "id": 7, "first": "द्वितीयं ब्रह्मचारिणी", "second": "तृतीयं चंद्रघंटेति" },
        { "id": 8, "first": "कूष्माण्डेति चतुर्थकम", "second": "पंचमं स्कंदमातेति" },
        { "id": 9, "first": "षष्ठं कात्यायनी तथा", "second": "सप्तमं कालरात्रिश्च" },
        { "id": 10, "first": "महागौरीच अष्टमम", "second": "नवमं सिद्धिदात्री च" },
        { "id": 11, "first": "नवदुर्गाः प्रकीर्तिताः", "second": "उक्तान्येतानि नामानि" },
        { "id": 12, "first": "ब्रह्मणैव महात्मना", "second": "अग्निना दह्यमानस्तु" },
        { "id": 13, "first": "शत्रुमध्ये गतो रणे", "second": "विषमे दुर्गमे चैव" },
        { "id": 14, "first": "भयार्तः शरणं गतः", "second": "न तेषां जायते किंचित" },
        { "id": 15, "first": "अशुभं रणसंकटे", "second": "नापदं तस्य पश्यामि" },
        { "id": 16, "first": "शोक दुखं भयं नहि", "second": "यैस्तु भक्त्या स्मृता नित्यं" }
      ]
    }
  ]
}
