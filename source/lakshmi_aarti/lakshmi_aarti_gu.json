{
  "sections": [
    {
      "id": "aarti",
      "verses": [
        { "id": 1, "first": "ૐ જય લક્ષ્મી માતા", "second": "મૈયા જય લક્ષ્મી માતા" },
        { "id": 2, "first": "તુમકો નિશદિન સેવત", "second": "હરિ વિષ્ણુ ધાતા" },
        { "id": 3, "first": "ઉમા રમા બ્રહ્માણી", "second": "તુમ હી જગ માતા" },
        { "id": 4, "first": "સૂર્ય ચંદ્રમા ધ્યાવત", "second": "નારદ ઋષિ ગાતા" },
        { "id": 5, "first": "દુર્ગા રૂપ નિરંજની", "second": "સુખ સંપતિ દાતા" },
        { "id": 6, "first": "જો કોઈ તુમકો ધ્યાવત", "second": "ઋદ્ધિ સિદ્ધિ ધન પાતા" },
        { "id": 7, "first": "તુમ પાતાલ નિવાસિની", "second": "તુમ હી શુભ દાતા" },
        { "id": 8, "first": "કર્મ પ્રભાવ પ્રકાશિની", "second": "ભવનિધિ કી ત્રાતા" },
        { "id": 9, "first": "જિસ ઘર મેં તુમ રહતી", "second": "સબ સદ્ગુણ આતા" },
        { "id": 10, "first": "સબ સંભવ હો જાતા", "second": "મન નહીં ઘબરાતા" },
        { "id": 11, "first": "તુમ બિન યજ્ઞ ન હોતે", "second": "વસ્ત્ર ન કોઈ પાતા" },
        { "id": 12, "first": "ખાન પાન કા વૈભવ", "second": "સબ તુમસે આતા" },
        { "id": 13, "first": "શુભ ગુણ મંદિર સુંદર", "second": "ક્ષીરોદધિ જાતા" },
        { "id": 14, "first": "રત્ન ચતુર્દશ તુમ બિન", "second": "કોઈ નહીં પાતા" },
        { "id": 15, "first": "મહા લક્ષ્મીજી કી આરતી", "second": "જો કોઈ જન ગાતા" },
        { "id": 16, "first": "ઉર આનંદ સમાતા", "second": "પાપ ઉતર જાતા" }
      ]
    }
  ]
}
