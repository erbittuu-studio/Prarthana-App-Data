{
  "sections": [
    {
      "id": "aarti",
      "verses": [
        { "id": 1, "first": "ॐ जय लक्ष्मी माता", "second": "मैया जय लक्ष्मी माता" },
        { "id": 2, "first": "तुमको निशदिन सेवत", "second": "हरि विष्णु धाता" },
        { "id": 3, "first": "उमा रमा ब्रह्माणी", "second": "तुम ही जग माता" },
        { "id": 4, "first": "सूर्य चंद्रमा ध्यावत", "second": "नारद ऋषि गाता" },
        { "id": 5, "first": "दुर्गा रूप निरंजनी", "second": "सुख संपति दाता" },
        { "id": 6, "first": "जो कोई तुमको ध्यावत", "second": "ऋद्धि सिद्धि धन पाता" },
        { "id": 7, "first": "तुम पाताल निवासिनी", "second": "तुम ही शुभ दाता" },
        { "id": 8, "first": "कर्म प्रभाव प्रकाशिनी", "second": "भवनिधि की त्राता" },
        { "id": 9, "first": "जिस घर में तुम रहती", "second": "सब सद्गुण आता" },
        { "id": 10, "first": "सब संभव हो जाता", "second": "मन नहीं घबराता" },
        { "id": 11, "first": "तुम बिन यज्ञ न होते", "second": "वस्त्र न कोई पाता" },
        { "id": 12, "first": "खान पान का वैभव", "second": "सब तुमसे आता" },
        { "id": 13, "first": "शुभ गुण मंदिर सुंदर", "second": "क्षीरोदधि जाता" },
        { "id": 14, "first": "रत्न चतुर्दश तुम बिन", "second": "कोई नहीं पाता" },
        { "id": 15, "first": "महा लक्ष्मीजी की आरती", "second": "जो कोई जन गाता" },
        { "id": 16, "first": "उर आनंद समाता", "second": "पाप उतर जाता" }
      ]
    }
  ]
}
