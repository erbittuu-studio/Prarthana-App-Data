{
  "sections": [
    {
      "id": "opening",
      "verses": [
        { "id": 1, "first": "निश्चय प्रेम प्रतीति ते, बिनय करैं सनमान", "second": "तेहि के कारज सकल शुभ, सिद्ध करैं हनुमान" },
        { "id": 2, "first": "जय हनुमंत संत हितकारी", "second": "सुनि लीजै प्रभु अरज हमारी" },
        { "id": 3, "first": "जन के काज बिलंब न कीजै", "second": "आतुर दौरि महा सुख दीजै" }
      ]
    },
    {
      "id": "main",
      "verses": [
        { "id": 4, "first": "जै जै जै हनुमान गोसाईं", "second": "कृपा करहु गुरुदेव की नाईं" },
        { "id": 5, "first": "जै गिरिधर जै जै सुखसागर", "second": "जै जै सेवक राज करागर" },
        { "id": 6, "first": "जै जै बजरंगी हनुमाना", "second": "जै जै देव पवन बलवाना" },
        { "id": 7, "first": "ॐ हनु हनु हनु हनुमंत हठीले", "second": "बैरिहि मारु बज्र की किले" },
        { "id": 8, "first": "गदा बज्र लै बैरिहि मारो", "second": "महाराज निज दास उबारो" },
        { "id": 9, "first": "ॐ ह्रीं ह्रीं ह्रीं हनुमंत कपीसा", "second": "ॐ हुं हुं हुं हनु अरि उर सीसा" },
        { "id": 10, "first": "सत्य होहु हरि शपथ पाई कै", "second": "राम दूत धरु मारु धाई कै" },
        { "id": 11, "first": "जय अंजनि कुमार बलवंता", "second": "शंकर सुवन वीर हनुमंता" },
        { "id": 12, "first": "बदन कराल काल कुल घालक", "second": "राम सहाय सदा प्रतिपालक" },
        { "id": 13, "first": "भूत प्रेत पिशाच निशाचर", "second": "अग्नि बेताल काल मारी मर" },
        { "id": 14, "first": "इनसे सब मम पीड़ा हरो", "second": "सकल कलेश मनोदुख टरो" },
        { "id": 15, "first": "हनुमान शक्ति ते भयभीता", "second": "हो जावैं सब प्रेत पलीता" },
        { "id": 16, "first": "खल बैरिहि मारो महिषाशन", "second": "राम दूत संकट को नाशन" },
        { "id": 17, "first": "खाय लै फल भूमि कंपावै", "second": "वज्र की किलकि बैरि भगावै" },
        { "id": 18, "first": "ॐ ह्नीं ह्नीं ह्नीं हनुमान धाओ", "second": "जहाँ रहो वहाँ जन बलि पाओ" },
        { "id": 19, "first": "हाथ बज्र सो बैरिहि पूरो", "second": "नख दंत से दुष्ट बिदारो" },
        { "id": 20, "first": "ॐ क्लीं क्लीं क्लीं क्लीं बजरंगी", "second": "मोहि दुःख से राखो जंगी" },
        { "id": 21, "first": "ॐ शत्रुन क्षोभय क्षोभय शत्रून", "second": "भूतानां भय दर्शय दर्शय" },
        { "id": 22, "first": "ॐ हनुमान मारो बज्र से", "second": "रोग भूत के भाग तेज से" },
        { "id": 23, "first": "ॐ हनुमते नमः दुःख हरो जी", "second": "ॐ महावीर विकट हरो जी" },
        { "id": 24, "first": "ॐ मारुतये नमः सुख करो जी", "second": "ॐ अंजनि सुत भय हरो जी" },
        { "id": 25, "first": "ॐ बज्र हनुमते नमः", "second": "ॐ राम दूताय नमः" },
        { "id": 26, "first": "ॐ नमो भगवते अंजनी पुत्राय", "second": "महाबलाय स्वाहा" },
        { "id": 27, "first": "ॐ नमो भगवते पवन पुत्राय", "second": "भूत भविष्यत वर्तमान" },
        { "id": 28, "first": "सब जग मांहिं प्रताप दिखाओ", "second": "सकल कलेश हमारो मिटाओ" }
      ]
    },
    {
      "id": "closing",
      "verses": [
        { "id": 29, "first": "जो यह बजरंग बाण पढ़ैगा", "second": "तासु के भय भूत सब भगैगा" },
        { "id": 30, "first": "ग्रह भूत निकट नहिं आवै", "second": "महावीर जब नाम सुनावै" },
        { "id": 31, "first": "तुलसीदास सदा हरि चेरा", "second": "कीजै नाथ हृदय महँ डेरा" }
      ]
    }
  ]
}
