{
  "sections": [
    {
      "id": "stotram",
      "verses": [
        { "id": 1, "first": "नमामीश्वरं सच्चिदानन्द रूपं", "second": "लसत्कुण्डलं गोकुले भ्राजमानम्" },
        { "id": 2, "first": "यशोदाभियोलूखलाद्धावमानं", "second": "परामृष्टमत्यन्ततो द्रुत्य गोप्या" },
        { "id": 3, "first": "रुदन्तं मुहुर्नेत्रयुग्मं मृजन्तं", "second": "करांभोजयुग्मेन सातंकनेत्रम्" },
        { "id": 4, "first": "मुहुः श्वासकम्पत्रिरेखांककण्ठ", "second": "स्थितग्रैवं दामोदरं भक्तिबद्धम्" },
        { "id": 5, "first": "इतीदृक्स्वलीलाभिरानन्दकुण्डे", "second": "स्वघोषं निमज्जन्तमाख्यापयन्तम्" },
        { "id": 6, "first": "तदीयेषितज्ञेषु भक्तैर्जितत्वं", "second": "पुनः प्रेमतस्तं शतावृत्ति वन्दे" },
        { "id": 7, "first": "वरं देव मोक्षं न मोक्षावधिं वा", "second": "न चान्यं वृणेऽहं वरेशादपीह" },
        { "id": 8, "first": "इदं ते वपुर्नाथ गोपालबालं", "second": "सदा मे मनस्याविरास्तां किमन्यैः" },
        { "id": 9, "first": "इदं ते मुखांभोजमत्यन्तनीलैर्", "second": "वृतं कुन्तलैः स्निग्धरक्तैश्च गोप्या" },
        { "id": 10, "first": "मुहुश्चुम्बितं बिम्बरक्ताधरं मे", "second": "मनस्याविरास्तामलं लक्षलाभैः" },
        { "id": 11, "first": "नमो देव दामोदरानन्त विष्णो", "second": "प्रसीद प्रभो दुःखजालाब्धिमग्नम्" },
        { "id": 12, "first": "कृपादृष्टिवृष्ट्यातिदीनं बतानु", "second": "गृहाणेश मामज्ञमेध्यक्षिदृश्यः" },
        { "id": 13, "first": "कुवेरात्मजौ बद्धमूर्त्यैव यद्वत्", "second": "त्वया मोचितौ भक्तिभाजौ कृतौ च" },
        { "id": 14, "first": "तथा प्रेमभक्तिं स्वकां मे प्रयच्छ", "second": "न मोक्षे ग्रहो मेऽस्ति दामोदरेह" },
        { "id": 15, "first": "नमस्तेऽस्तु दाम्ने स्फुरद्दीप्तिधाम्ने", "second": "त्वदीयोदरायाथ विश्वस्य धाम्ने" },
        { "id": 16, "first": "नमो राधिकायै त्वदीयप्रियायै", "second": "नमोऽनन्तलीलाय देवाय तुभ्यम्" }
      ]
    }
  ]
}
