        { "id": 10, "first": "મુહુશ્ચુંબિતં બિંબરક્તાધરં મે", "second": "મનસ્યાવિરાસ્તામલં લક્ષલાભૈઃ" },
        { "id": 11, "first": "નમો દેવ દામોદરાનંત વિષ્ણો", "second": "પ્રસીદ પ્રભો દુઃખજાલાબ્ધિમગ્નમ્" },
        { "id": 12, "first": "કૃપાદૃષ્ટિવૃષ્ટ્યાતિદીનં બતાનુ", "second": "ગૃહાણેશ મામજ્ઞમેધ્યક્ષિદૃશ્યઃ" },
        { "id": 13, "first": "કુવેરાત્મજૌ બદ્ધમૂર્ત્યૈવ યદ્વત્", "second": "ત્વયા મોચિતૌ ભક્તિભાજૌ કૃતૌ ચ" },
