{
  "sections": [
    {
      "id": "opening",
      "verses": [
        { "id": 1, "first": "जय गणेश गिरिजा सुवन, मंगल मूल सुजान", "second": "कहत अयोध्यादास तुम, देहु अभय वरदान" },
        { "id": 2, "first": "जय जय श्री शनिदेव प्रभु, सुनहु विनय महाराज", "second": "करहु कृपा हे रवि तनय, राखहु जन की लाज" }
      ]
    },
    {
      "id": "chaupai",
      "verses": [
        { "id": 3, "first": "जयति जयति शनिदेव दयाला", "second": "करत सदा भक्तन प्रतिपाला" },
        { "id": 4, "first": "चार भुजा तनु श्याम विराजे", "second": "माथे रतन मुकुट छबि छाजे" },
        { "id": 5, "first": "परम विशाल मनोहर भाला", "second": "नील वस्त्र तनु उपर डाला" },
        { "id": 6, "first": "हाथ गदा त्रिशूल कुठारा", "second": "पल बिच करें अरि संहारा" },
        { "id": 7, "first": "पिंगल नयन कृष्ण तनु माहीं", "second": "समान तेज ब्रह्मांड न नाहीं" },
        { "id": 8, "first": "मेष वाहन अति सोहे पाई", "second": "विषम दृष्टि अति शक्ति सुहाई" },
        { "id": 9, "first": "पंचानन कर सूर्य सुपूजा", "second": "और देव तुम सम नहिं दूजा" },
        { "id": 10, "first": "सूर्य पुत्र प्रभु दिनकर नामा", "second": "छाया गर्भ सिंहासन पामा" },
        { "id": 11, "first": "कर्मफल प्रदाता सुखकारी", "second": "विधि हरि हर त्रिपुरारी भारी" },
        { "id": 12, "first": "बड़े कोप ते राहु धरायो", "second": "दक्षिण दिशा आस्य जग गायो" },
        { "id": 13, "first": "धूम्र केतु सम शोभा पावे", "second": "पाप पुंज नाशक बिरदावे" },
        { "id": 14, "first": "जो जन जन्म शनि जो पावे", "second": "प्रभु पद नित्य सोई मनभावे" },
        { "id": 15, "first": "ब्रह्मा विष्णु शिव सुर मुनि माहीं", "second": "शनि प्रकोप भय बचे जो नाहीं" },
        { "id": 16, "first": "राजा इंद्र नहुष बलि कारी", "second": "सभी किए शनि देव दुखारी" },
        { "id": 17, "first": "रामचंद्र पर भी शनि आए", "second": "बिना बात बनवास कराए" },
        { "id": 18, "first": "सीता हरण भयो दशकंधर", "second": "लक्ष्मण भए मूर्च्छा कर बंदर" },
        { "id": 19, "first": "रावण पर भी शनि जब आई", "second": "लंका दहन भई असि भाई" },
        { "id": 20, "first": "कौरव पांडव भी शनि ग्रसे", "second": "भारत बीच महाभारत बसे" },
        { "id": 21, "first": "नल नरेश पर शनि जब ढाए", "second": "भ्रष्ट राज्य कष्ट सब पाए" },
        { "id": 22, "first": "राजा हरिश्चंद्र को धरा", "second": "छाड़ि राज्य रंकन में करा" },
        { "id": 23, "first": "विक्रमादित्य सबल प्रतापी", "second": "शनि दशा में भए अनलापी" },
        { "id": 24, "first": "और अनेक नरेश जहान", "second": "किए शनि ने हाल बेहाल" },
        { "id": 25, "first": "किन्तु कृपा जब शनि की होई", "second": "उत्तम से उत्तम फल होई" },
        { "id": 26, "first": "कंचन थार भरे मनभावन", "second": "उर आनंद समृद्धि सुहावन" },
        { "id": 27, "first": "शनि वक्र दृष्टि अंध बनावे", "second": "सरल दृष्टि राज्य सुख पावे" },
        { "id": 28, "first": "शिव के हुए जो एक निशाने", "second": "नाम गुण महात्म्य को जाने" },
        { "id": 29, "first": "कोटि भानु प्रकाश जो प्यारा", "second": "हाथ कमल शोभित रुद्राक्ष हारा" },
        { "id": 30, "first": "कृष्ण वर्ण अति सोहनि काया", "second": "शिव पूजन करि सब सुख पाया" },
        { "id": 31, "first": "अम्बर नव ग्रह में प्रधान", "second": "शुभ अशुभ शनि करे विधान" },
        { "id": 32, "first": "जो चाहे सुख सम्पत्ति नाना", "second": "सेवा करे शनि देव को मन में लाना" },
        { "id": 33, "first": "ग्रह सब बली शनि बलवाना", "second": "साढ़ेसाती दशा प्रधाना" },
        { "id": 34, "first": "छोटी दशा बारह मास अहै", "second": "मध्य दशा संग तीस रहै" },
        { "id": 35, "first": "प्रथम दशा तीस दिन जानो", "second": "भक्ति भाव मन में सब मानो" },
        { "id": 36, "first": "शनि देव की ऐसी महिमा", "second": "भक्त जन की करते सब क्षमा" },
        { "id": 37, "first": "जो नर निज कर इसको गावे", "second": "साढ़ेसाती का भय नहिं आवे" },
        { "id": 38, "first": "मेष राशि वृष और मिथुन में", "second": "कर्क सिंह कन्या वर में" },
        { "id": 39, "first": "तुला वृश्चिक और धनु में", "second": "मकर कुंभ मीन लगन में" },
        { "id": 40, "first": "सब राशि में शनि जब आवे", "second": "शुभाशुभ गति तब ही पावे" },
        { "id": 41, "first": "तेल तिलहन दान शनि को करे", "second": "दुख दारिद्र्य सर्व भय हरे" },
        { "id": 42, "first": "दोहा चौपाई आरती गाए", "second": "इच्छित वर शनिदेव से पाए" }
      ]
    },
    {
      "id": "closing",
      "verses": [
        { "id": 43, "first": "इति श्री शनि चालीसा सम्पूर्ण", "second": "शनि प्रसाद सदा शुभ पूर्ण" }
      ]
    }
  ]
