{
  "sections": [
    {
      "id": "stotram",
      "verses": [
        { "id": 1, "first": "अधरं मधुरं वदनं मधुरं", "second": "नयनं मधुरं हसितं मधुरं" },
        { "id": 2, "first": "हृदयं मधुरं गमनं मधुरं", "second": "मधुराधिपतेरखिलं मधुरं" },
        { "id": 3, "first": "वचनं मधुरं चरितं मधुरं", "second": "वसनं मधुरं वलितं मधुरं" },
        { "id": 4, "first": "चलितं मधुरं भ्रमितं मधुरं", "second": "मधुराधिपतेरखिलं मधुरं" },
        { "id": 5, "first": "वेणुर्मधुरो रेणुर्मधुरः", "second": "पाणिर्मधुरः पादौ मधुरौ" },
        { "id": 6, "first": "नृत्यं मधुरं सख्यं मधुरं", "second": "मधुराधिपतेरखिलं मधुरं" },
        { "id": 7, "first": "गीतं मधुरं पीतं मधुरं", "second": "भुक्तं मधुरं सुप्तं मधुरं" },
        { "id": 8, "first": "रूपं मधुरं तिलकं मधुरं", "second": "मधुराधिपतेरखिलं मधुरं" },
        { "id": 9, "first": "करणं मधुरं तरणं मधुरं", "second": "हरणं मधुरं रमणं मधुरं" },
        { "id": 10, "first": "वमितं मधुरं शमितं मधुरं", "second": "मधुराधिपतेरखिलं मधुरं" },
        { "id": 11, "first": "गुञ्जा मधुरा माला मधुरा", "second": "यमुना मधुरा वीची मधुरा" },
        { "id": 12, "first": "सलिलं मधुरं कमलं मधुरं", "second": "मधुराधिपतेरखिलं मधुरं" },
        { "id": 13, "first": "गोपी मधुरा लीला मधुरा", "second": "युक्तं मधुरं मुक्तं मधुरं" },
        { "id": 14, "first": "दृष्टं मधुरं शिष्टं मधुरं", "second": "मधुराधिपतेरखिलं मधुरं" },
        { "id": 15, "first": "गोपा मधुरा गावो मधुरा", "second": "यष्टिर्मधुरा सृष्टिर्मधुरा" },
        { "id": 16, "first": "दलितं मधुरं फलितं मधुरं", "second": "मधुराधिपतेरखिलं मधुरं" }
      ]
    }
  ]
}
