        { "id": 1, "first": "शुक्लाम बरधरम विष्णुं", "second": "शशिवर्णं चतुर्भुजम" },
        { "id": 2, "first": "प्रसन्न वदनं ध्यायेत", "second": "सर्व विघ्नोप शान्तये" },
